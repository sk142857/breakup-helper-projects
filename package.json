{
  "name": "breakup-helper",
  "private": true,
  "scripts": {
    "env:dev": "pnpm --filter @app/helper-api-service env:dev",
    "env:prod": "pnpm --filter @app/helper-api-service env:prod",
    "dev": "concurrently -k -n api,admin -c cyan,green \"pnpm dev:server\" \"pnpm dev:admin\"",
    "dev:server": "pnpm --filter @app/helper-api-service dev",
    "dev:admin": "pnpm --filter @app/helper-admin-pro dev",
    "dev:miniapp": "pnpm --filter @app/helper-miniapp dev",
    "build:server": "pnpm --filter @app/helper-api-service build",
    "build:admin": "pnpm --filter @app/helper-admin-pro build",
    "db:push": "pnpm --filter @app/helper-api-service db:push",
    "db:studio": "pnpm --filter @app/helper-api-service db:studio",
    "db:generate": "pnpm --filter @app/helper-api-service db:generate",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
