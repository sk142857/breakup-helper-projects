/* 全局样式 - 断联计划 */
page {
  --primary: #f6685d;
  --primary-light: #fde8e5;
  --success: #34C759;
  --warning: #FF9500;
  --danger: #FF3B30;
  --bg: #F5F5FA;
  --card-bg: #FFFFFF;
  --text-primary: #1A1A1A;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #EEEEEE;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  --spacing-h: 32rpx;

  /* TDesign 品牌色覆盖（主题色 #f6685d） */
  --td-brand-color: #f6685d;
  --td-brand-color-active: #e0554a;
  --td-brand-color-light: #fde8e5;
  --td-brand-color-light-active: #fcd5d0;
  --td-brand-color-disabled: #f9b8b2;

  /* TDesign 导航栏变量 */
  --td-navbar-bg-color: #FFFFFF;
  --td-navbar-color: #1A1A1A;
  --td-navbar-height: 48px;

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background: var(--bg);
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin: 24rpx var(--spacing-h);
  box-shadow: var(--shadow);
}

/* 通用左右屏距容器 */
.page-padding {
  padding-left: var(--spacing-h);
  padding-right: var(--spacing-h);
}

/* 通用页面容器 */
.page-container {
  background: var(--bg);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 32rpx var(--spacing-h) 16rpx;
}

/* Flex 工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

/* 间距 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-24 { padding: 24rpx; }

/* 文字 */
.text-center { text-align: center; }
.text-hint { color: var(--text-hint); font-size: 24rpx; }
.text-secondary { color: var(--text-secondary); font-size: 26rpx; }

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}
.tag-primary { background: var(--primary-light); color: var(--primary); }
.tag-success { background: #E8F8ED; color: var(--success); }
.tag-warning { background: #FFF3E0; color: var(--warning); }
.tag-danger { background: #FFEBEE; color: var(--danger); }

/* Skyline 滚动容器：显式高度让 Skyline 正确计算滚动视口 */
.page-scroll {
  height: 100vh;
}
