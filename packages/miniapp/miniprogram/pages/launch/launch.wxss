.launch-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #1a1a2e;
}

.launch-logo {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.launch-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #f0f0f0;
  margin-bottom: 24rpx;
}

.launch-subtitle {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 48rpx;
}

.launch-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(246, 104, 93, 0.2);
  border-top-color: #f6685d;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
