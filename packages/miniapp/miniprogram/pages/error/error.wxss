.error-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx;
  background: #1a1a2e;
}

.error-icon {
  font-size: 160rpx;
  margin-bottom: 32rpx;
}

.error-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #e0e0e0;
  margin-bottom: 16rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 64rpx;
  padding: 0 32rpx;
}

.retry-btn {
  width: 400rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f6685d, #e0403a);
  border-radius: 44rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(246, 104, 93, 0.3);
}

.retry-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}
