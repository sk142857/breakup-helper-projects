# ============================================
# 开发环境
# 使用本地已安装的 MySQL + Redis，无需 Docker
# ============================================

# 数据库连接 (本地 MySQL)
DATABASE_URL="mysql://root:123456@localhost:3306/aliyun_breakup_helper"

# JWT 密钥
JWT_SECRET="dev-jwt-secret-not-for-production"

# JWT 过期时间（秒）
JWT_EXPIRES_IN="7200"

# Open API 签名有效期（秒）
SIGNATURE_TTL="300"

# Redis (本地)
REDIS_URL="redis://localhost:6379"

# 微信小程序
WECHAT_APPID="your-miniapp-appid"
WECHAT_APPSECRET="your-miniapp-appsecret"
