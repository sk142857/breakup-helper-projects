<!-- 感情列表页 -->
<t-navbar title="我的感情" fixed placeholder></t-navbar>
<scroll-view type="custom" scroll-y class="page-scroll">
  <view class="page-container">

    <!-- 感情列表 -->
    <view class="list-wrap">
      <view wx:for="{{list}}" wx:key="relId" class="rel-card {{item.relStatus === 'done' ? 'rel-card-done' : ''}}" data-id="{{item.relId}}" bindtap="onTapItem">
        <!-- 卡片顶部装饰区 -->
        <view class="rel-card-cover {{'rel-cover-' + (item.relStatus === 'active' ? 'active' : item.relStatus === 'done' ? 'done' : 'paused')}}">
          <view class="rel-card-avatar">
            <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="rel-avatar-img" />
            <view wx:else class="rel-avatar-placeholder {{'rel-avatar-bg-' + (item.relType || 'other')}}">
              <text class="rel-avatar-char">{{item._avatarChar}}</text>
            </view>
          </view>
          <view class="rel-card-header-right">
            <text class="rel-card-name">{{item.nickname}}</text>
            <text class="rel-card-type">{{item._relTypeEmoji}} {{item._relTypeLabel}}</text>
          </view>
          <view class="rel-card-delete" data-id="{{item.relId}}" catchtap="onDeleteItem">
            <t-icon name="delete" size="32rpx" color="#C7C7CC" />
          </view>
        </view>

        <!-- 卡片主体 -->
        <view class="rel-card-body">

          <!-- 状态 / 持续 / 断联 -->
          <view class="rel-card-info">
            <view class="rel-info-item">
              <text class="rel-info-label">状态</text>
              <text class="rel-info-value rel-info-status {{'rel-text-' + item.relStatus}}">{{item._relStatusLabel}}</text>
            </view>
            <view class="rel-info-divider"></view>
            <view class="rel-info-item">
              <text class="rel-info-label">持续</text>
              <text class="rel-info-value rel-info-highlight">{{item._durationText}}</text>
            </view>
            <view class="rel-info-divider"></view>
            <view class="rel-info-item">
              <text class="rel-info-label">断联</text>
              <text class="rel-info-value">{{item.breakDays}} 天</text>
            </view>
          </view>

          <!-- 日期区间 -->
          <view class="rel-card-dates">
            <text class="rel-date-text">{{item.startDate}}</text>
            <text wx:if="{{item.endDate}}" class="rel-date-arrow">→</text>
            <text wx:if="{{item.endDate}}" class="rel-date-text">{{item.endDate}}</text>
          </view>

          <!-- 进度条 -->
          <view class="rel-card-progress">
            <view class="rel-progress-track">
              <view class="rel-progress-fill {{'rel-progress-' + item.relStatus}}" style="width: {{Math.min(item.breakDays / Math.max(item.breakTargetDays, 1) * 100, 100)}}%;"></view>
            </view>
            <view class="rel-progress-bottom">
              <text class="rel-progress-label">{{item.breakDays}} / {{item.breakTargetDays}} 天</text>
              <text wx:if="{{item.relStatus !== 'done' && item.breakTargetDays > item.breakDays}}" class="rel-progress-remain">剩余 {{item.breakTargetDays - item.breakDays}} 天</text>
              <text wx:elif="{{item.relStatus === 'done'}}" class="rel-progress-remain">✓ 已达成</text>
              <text wx:else class="rel-progress-remain">已超期 {{item.breakDays - item.breakTargetDays}} 天</text>
            </view>
          </view>

          <!-- 备注预览 -->
          <view wx:if="{{item.note}}" class="rel-card-note">
            <t-icon name="quote" size="24rpx" color="#ccc" />
            <text class="rel-note-text">{{item.note}}</text>
          </view>

          <!-- 图片墙：独占一行，最多 6 张 -->
          <view wx:if="{{item._displayImages.length}}" class="rel-card-images">
            <view wx:for="{{item._displayImages}}" wx:for-item="img" wx:key="fileId" class="rel-img-item">
              <image src="{{img.thumbUrl || img.origUrl}}" mode="aspectFill" class="rel-img-thumb" />
              <!-- 第3张且有更多时显示 +N -->
              <view wx:if="{{item._imageMore && index === 2}}" class="rel-img-more">
                <text class="rel-img-more-text">+{{item._imageMore}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 日期脚标 -->
        <view class="rel-card-footer">
          <text class="rel-footer-text">更新于 {{item._updatedLabel}}</text>
        </view>
      </view>

      <view wx:if="{{list.length === 0 && !loading}}" class="empty-state">
        <t-icon name="heart" size="100rpx" color="#ddd" />
        <text class="empty-title">还没有感情记录</text>
        <text class="empty-desc">点击右下角 + 新增一段关系</text>
      </view>
    </view>

  </view>
</scroll-view>

<!-- 悬浮新增按钮 -->
<view class="fab-btn" bindtap="onAdd">
  <t-icon name="add" size="48rpx" color="#fff" />
</view>
