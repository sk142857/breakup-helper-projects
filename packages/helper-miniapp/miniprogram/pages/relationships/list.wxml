<!-- 感情列表页 -->
<t-navbar title="我的感情" fixed placeholder></t-navbar>
<scroll-view type="custom" scroll-y class="page-scroll">
  <view class="page-container">

    <!-- 分类标签 -->
    <view class="filter-bar">
      <view class="filter-item {{filterTab === 'all' ? 'filter-active' : ''}}" data-tab="all" bindtap="onFilter">
        <text>全部</text>
      </view>
      <view class="filter-item {{filterTab === 'active' ? 'filter-active' : ''}}" data-tab="active" bindtap="onFilter">
        <text>进行中</text>
        <view class="filter-badge">2</view>
      </view>
      <view class="filter-item {{filterTab === 'done' ? 'filter-active' : ''}}" data-tab="done" bindtap="onFilter">
        <text>已结束</text>
        <view class="filter-badge filter-badge-done">1</view>
      </view>
    </view>

    <!-- 感情列表 -->
    <view class="list-wrap">
      <!-- AI: block包装wx:for避免迭代器与元素属性冲突 -->
      <block wx:for="{{list}}" wx:key="relId">
      <view class="relation-card {{item.relStatus === 'done' ? 'relation-card-done' : ''}}" data-id="{{item.relId}}" bindtap="onTapItem">
        <view class="card-header flex-between">
          <view class="flex-row">
            <view wx:if="{{item.avatarUrl}}" class="avatar">
              <image src="{{item.avatarUrl}}" mode="aspectFill" style="width: 80rpx; height: 80rpx; border-radius: 50%;" />
            </view>
            <view wx:else class="avatar avatar-green">
              <t-icon name="user" size="48rpx" color="#fff" />
            </view>
            <view class="card-header-info">
              <text class="card-title">{{item.nickname}}</text>
              <text class="card-subtitle">{{item.relTypeLabel}} · {{item.startDate}}</text>
            </view>
          </view>
          <view class="tag {{item.relStatus === 'active' ? 'tag-warning' : item.relStatus === 'done' ? 'tag-success' : 'tag-default'}}">
            {{item.relStatusLabel}}
          </view>
        </view>
        <view class="card-body">
          <view class="flex-between mb-16">
            <text class="text-secondary">已断联 {{item.breakDays}} 天</text>
          </view>
          <view class="progress-wrap">
            <t-progress percentage="{{Math.min(item.breakDays / item.breakTargetDays * 100, 100)}}" stroke-width="12rpx" color="{{item.relStatus === 'done' ? '#34C759' : '#f6685d'}}" track-color="#fde8e5" />
            <text class="progress-hint">目标 {{item.breakTargetDays}} 天 · {{item.relStatus === 'done' ? '已达成 ✓' : '还剩 ' + (item.breakTargetDays > item.breakDays ? item.breakTargetDays - item.breakDays : 0) + ' 天'}}</text>
          </view>
        </view>
      </view>
      </block>

      <view wx:if="{{list.length === 0 && !loading}}" class="empty-state">
        <t-icon name="heart" size="100rpx" color="#ddd" />
        <text class="empty-title">还没有感情记录</text>
        <text class="empty-desc">点击右下角 + 新增一段关系</text>
      </view>
    </view>



  </view>
</scroll-view>

<!-- 悬浮新增按钮（置于 scroll-view 外以保持 fixed 定位） -->
<view class="fab-btn" bindtap="onAdd">
  <t-icon name="add" size="48rpx" color="#fff" />
</view>
