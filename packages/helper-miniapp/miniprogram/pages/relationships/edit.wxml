<!-- 新增/编辑感情页 - 分步卡片 -->
<t-navbar title="{{editId ? '编辑感情' : '新增感情'}}" fixed left-arrow placeholder></t-navbar>
<scroll-view type="custom" scroll-y class="page-scroll">
  <view class="page-container">

  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step-row">
      <block wx:for="{{steps}}" wx:key="index">
        <view class="step-dot-wrap">
          <view class="step-dot {{index < step ? 'step-done' : ''}} {{index === step ? 'step-current' : ''}}">
            <t-icon wx:if="{{index < step}}" name="check" size="28rpx" color="#fff" />
            <text wx:else>{{index + 1}}</text>
          </view>
          <text class="step-label {{index === step ? 'step-label-active' : ''}}">{{item}}</text>
        </view>
        <view wx:if="{{index < steps.length - 1}}" class="step-line {{index < step ? 'step-line-done' : ''}}"></view>
      </block>
    </view>
  </view>

  <!-- 步骤卡片 -->
  <view class="step-card-wrap">

    <!-- Step 0: 头像昵称（独立步骤） -->
    <view class="step-card" wx:if="{{step === 0}}">
      <view class="avatar-section">
        <view class="avatar-upload" bindtap="onChooseAvatar">
          <view class="avatar-circle">
            <image wx:if="{{avatarUrl}}" class="avatar-preview" src="{{avatarUrl}}" mode="aspectFill" />
            <view wx:else class="avatar-lg avatar-green">
              <t-icon name="camera" size="56rpx" color="#fff" />
            </view>
          </view>
          <text class="avatar-hint">{{avatarUrl ? '点击更换头像' : '点击设置头像'}}</text>
        </view>
      </view>
      <view wx:if="{{editId}}" class="form-item">
        <view class="form-label">感情编号</view>
        <view class="form-row form-row-readonly">
          <text class="form-text">{{editId}}</text>
        </view>
      </view>
      <view class="form-item">
        <view class="form-label">昵称/代号</view>
        <view class="form-row">
          <input class="form-text" style="flex:1;" placeholder="输入对方的昵称或代号" value="{{name}}" bindinput="onNameChange" placeholder-style="color:var(--text-hint);" adjust-position="{{false}}" />
        </view>
      </view>
    </view>

    <!-- Step 1: 关系类型（小卡片选项，不弹 picker） -->
    <view class="step-card" wx:if="{{step === 1}}">
      <view class="form-item">
        <!-- 这里暂时隐藏，禁止AI优化 -->
        <view class="form-label" style="display:none;">你们的关系是？</view>
        <view class="option-grid option-grid-2">
          <view
            wx:for="{{typeOptions}}"
            wx:key="value"
            class="option-card {{typeValue === item.value ? 'option-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onSelectType"
          >
            <text class="option-emoji">{{item.emoji}}</text>
            <text class="option-label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Step 2: 日期设置（picker-view 滚轮） -->
    <view class="step-card" wx:if="{{step === 2}}">
      <view class="form-item">
        <view class="form-label">目标天数</view>
        <view class="form-row">
          <text class="{{goalDaysText ? 'form-text' : 'form-placeholder'}}">{{goalDaysText || '请设置起止日期'}} 天</text>
        </view>
        <view wx:if="{{goalDays > 0}}" class="goal-hint">
          <t-icon name="info-circle" size="28rpx" color="var(--primary)" />
          <text>根据起止日期自动计算，共 {{goalDays}} 天</text>
        </view>
      </view>
      <view class="form-item">
        <view class="form-label">开始日期</view>
        <view class="form-row" bindtap="onTapStartDate">
          <text class="{{startDate ? 'form-text' : 'form-placeholder'}}">{{startDate || '请选择开始日期'}}</text>
          <text class="picker-arrow">▾</text>
        </view>
      </view>
      <view class="form-item">
        <view class="form-label">结束日期（选填）</view>
        <view class="form-row" bindtap="onTapEndDate">
          <text class="{{endDate ? 'form-text' : 'form-placeholder'}}">{{endDate || '请选择结束日期'}}</text>
          <text class="picker-arrow">▾</text>
        </view>
        <view wx:if="{{endDate && endDate < startDate}}" class="form-tip form-tip-error">
          结束日期不能早于开始日期
        </view>
      </view>
      <view wx:if="{{dateEditTarget}}" class="date-picker-wrap">
        <picker-view indicator-style="height: 80rpx;" style="width: 100%; height: 300rpx;" value="{{dateEditTarget === 'start' ? startDateIndex : endDateIndex}}" bindchange="onDatePickerChange">
          <picker-view-column>
            <block wx:for="{{years}}" wx:key="*this"><view class="picker-item">{{item}}年</view></block>
          </picker-view-column>
          <picker-view-column>
            <block wx:for="{{months}}" wx:key="*this"><view class="picker-item">{{item}}月</view></block>
          </picker-view-column>
          <picker-view-column>
            <block wx:for="{{days}}" wx:key="*this"><view class="picker-item">{{item}}日</view></block>
          </picker-view-column>
        </picker-view>
      </view>
    </view>

    <!-- Step 3: 当前状态（小卡片选项，不弹 picker） -->
    <view class="step-card" wx:if="{{step === 3}}">
      <view class="form-item">
        <view class="form-label" style="display:none;">当前状态</view>
        <view class="option-grid option-grid-2">
          <view
            wx:for="{{statusOptions}}"
            wx:key="value"
            class="option-card {{status === item.value ? 'option-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="onSelectStatus"
          >
            <text class="option-emoji">{{item.emoji}}</text>
            <text class="option-label">{{item.label}}</text>
            <text class="option-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Step 4: 备注图片（独立步骤，九宫格布局最多 9 张） -->
    <view class="step-card" wx:if="{{step === 4}}">
      <view class="form-item">
        <view class="form-label">备注（可选）</view>
        <view class="form-textarea-wrap">
          <t-textarea placeholder="记录这段感情的一些回忆或想法..." value="{{note}}" bindchange="onNoteChange" maxlength="{{200}}" autosize adjust-position="{{false}}" />
        </view>
      </view>
      <view class="form-item">
        <view class="form-label">图片（可选）</view>
        <view class="upload-grid">
          <block wx:for="{{slots}}" wx:key="*this">
            <view class="upload-item">
              <view class="upload-spacer"></view>
              <view class="upload-inner">
                <block wx:if="{{imageUrls[item] || images[item]}}">
                  <image class="upload-img" src="{{imageUrls[item] || images[item]}}" mode="aspectFill" />
                  <view class="upload-delete" data-index="{{item}}" catchtap="onDelImage">
                    <t-icon name="close-circle-filled" size="36rpx" color="#FF3B30" />
                  </view>
                </block>
                <view wx:elif="{{item === 0}}" class="upload-add" bindtap="onChooseImage" data-index="{{item}}">
                  <t-icon name="add" size="56rpx" color="#ccc" />
                </view>
                <view wx:else class="upload-placeholder" bindtap="onChooseImage" data-index="{{item}}">
                  <t-icon name="image" size="48rpx" color="#ccc" />
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>

  </view>

  <!-- 底部按钮组 -->
  <view class="form-bottom step-bottom">
    <t-button wx:if="{{step > 0}}" theme="default" size="large" shape="round" t-class="btn-half" bindtap="onPrevStep">
      上一步
    </t-button>
    <t-button wx:if="{{step < steps.length - 1}}" theme="primary" size="large" shape="round" t-class="{{step > 0 ? 'btn-half' : 'btn-full'}}" bindtap="onNextStep">
      下一步
    </t-button>
    <t-button wx:if="{{step === steps.length - 1}}" theme="primary" size="large" shape="round" t-class="{{step > 0 ? 'btn-half' : 'btn-full'}}" bindtap="onSave">
      保存
    </t-button>
  </view>

  <view style="height: 160rpx;"></view>

  </view>
</scroll-view>
