/* Skyline 页面滚动布局 */
page { overflow: hidden; }

/* 感情详情页样式 */

/* 底部按钮栏高度补偿 */
.page-container {
  padding-bottom: calc(400rpx + env(safe-area-inset-bottom));
}

/* 档案卡片 */
.profile-card {
  background: var(--card-bg);
  margin: var(--spacing-h);
  padding: 40rpx 32rpx 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}
.profile-avatar {
  margin-bottom: 20rpx;
}
.avatar-circle-sm {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  overflow: hidden;
  display: inline-block;
}
.avatar-preview-sm {
  width: 100%;
  height: 100%;
  display: block;
}

.card-delete-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(142, 142, 147, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.avatar-lg {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-green { background: linear-gradient(135deg, #34C759, #30D158); }

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
.profile-tags {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.profile-dates {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 进度卡片 */
.progress-card {
  background: var(--card-bg);
  margin: 0 var(--spacing-h) var(--spacing-h);
  padding: 32rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
}
.progress-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.progress-main {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.progress-big {
  display: flex;
  align-items: baseline;
}
.progress-num {
  font-size: 72rpx;
  font-weight: 800;
  color: var(--primary);
  line-height: 1;
}
.progress-unit {
  font-size: 28rpx;
  color: var(--text-hint);
  margin-left: 8rpx;
}
.progress-detail {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.progress-label {
  font-size: 26rpx;
  color: var(--warning);
  font-weight: 600;
}
.progress-bar-wrap {
  margin-top: 4rpx;
}

/* 时间线 */
.section-header {
  padding: 16rpx var(--spacing-h) 8rpx;
}

/* 空状态 */
.empty-state {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-title {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 24rpx;
}
.empty-desc {
  font-size: 24rpx;
  color: #d0d0d0;
  margin-top: 8rpx;
}
.timeline {
  padding: 24rpx;
  margin: 0 var(--spacing-h);
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  min-height: 260rpx;
  position: relative;
}
.timeline-item {
  display: flex;
  flex-direction: row;
  position: relative;
}
.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  flex-shrink: 0;
  z-index: 1;
}
.timeline-dot-primary { background: var(--primary); }
.timeline-dot-blue { background: #5B8DEF; }
.timeline-dot-red { background: var(--danger); }

.timeline-line {
  width: 4rpx;
  background: #E8E8ED;
  position: absolute;
  left: 8rpx;
  top: 36rpx;
  bottom: -16rpx;
  z-index: 0;
}
.timeline-item:last-child .timeline-line {
  display: none;
}
.timeline-content {
  flex: 1;
  margin-left: 24rpx;
  padding-bottom: 32rpx;
}
.timeline-header {
  margin-bottom: 12rpx;
}
.timeline-date {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 16rpx;
}
.timeline-day {
  font-size: 22rpx;
  color: var(--text-hint);
}
.timeline-mood {
  font-size: 24rpx;
}
.timeline-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ── 资料操作链接 ── */
.action-links {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 48rpx;
  padding: 24rpx 0 16rpx;
  margin-top: 8rpx;
}
.action-link {
  font-size: 26rpx;
  color: var(--text-hint);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
}
.action-link-danger {
  color: #FF3B30;
}
.timeline-images {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 16rpx;
}
.timeline-delete {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.timeline-emoji-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 8rpx;
}
.timeline-emoji {
  font-size: 40rpx;
  line-height: 1;
}
.timeline-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: var(--bg);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx var(--spacing-h) calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid var(--border);
}
.bottom-btn-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  width: 100%;
}

/* 断联期切换器 */
.session-switcher {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}
.session-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
}
.session-item-active {
  background: #fff5f4;
}
.session-item-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.session-item-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}
.session-item-date {
  font-size: 22rpx;
  color: #999;
}
.session-item-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.session-item-count {
  font-size: 24rpx;
  color: #666;
}
.session-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #eee;
}
.session-action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  border: 2rpx solid #eee;
  font-size: 24rpx;
  color: #666;
}
.flex-row {
  display: flex;
  align-items: center;
}
