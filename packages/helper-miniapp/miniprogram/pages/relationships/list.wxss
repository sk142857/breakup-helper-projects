/* Skyline 页面滚动布局 */
page { overflow: hidden; background: #f5f5f7; }

/* 感情列表页 - 唯美卡片设计 */

.list-wrap {
  padding: 8rpx 0 120rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 30vh;
}
.empty-title {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 24rpx;
}
.empty-desc {
  font-size: 24rpx;
  color: #d0d0d0;
  margin-top: 8rpx;
}

/* ===== 感情卡片 ===== */
.rel-card {
  margin: 16rpx 20rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04), 0 0 2rpx rgba(0,0,0,0.06);
  overflow: hidden;
  transition: all 0.2s;
  position: relative;
}
.rel-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 8rpx rgba(0,0,0,0.06);
}
.rel-card-done {
  opacity: 0.75;
}

/* ---- 卡片顶部装饰区 ---- */
.rel-card-cover {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 28rpx 0;
  position: relative;
}
.rel-cover-active {
  /* 进行中 - 暖色渐变氛围 */
}
.rel-cover-done {
  /* 已结束 - 简洁 */
}
.rel-cover-paused {
  /* 暂停中 */
}

/* 头像 */
.rel-card-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.rel-avatar-img {
  width: 100%;
  height: 100%;
}
.rel-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rel-avatar-char {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(0,0,0,0.5);
}
.rel-avatar-bg-first_love { background: linear-gradient(135deg, #FFE5E5, #FFB8C6); }
.rel-avatar-bg-ex { background: linear-gradient(135deg, #E8E8F0, #C8C8D8); }
.rel-avatar-bg-crush { background: linear-gradient(135deg, #FFF0E0, #FFD4A8); }
.rel-avatar-bg-situationship { background: linear-gradient(135deg, #E0F0FF, #A8D0F0); }
.rel-avatar-bg-blind_date { background: linear-gradient(135deg, #E8FFE8, #B8E8B8); }
.rel-avatar-bg-other { background: linear-gradient(135deg, #F0E8FF, #D0C0F0); }

/* 右侧文字 */
.rel-card-header-right {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}
.rel-card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}
.rel-card-type {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

/* 状态徽标 */
.rel-card-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  padding: 6rpx 18rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
}
.badge-active {
  background: #FFF0EE;
  color: #f6685d;
}
.badge-done {
  background: #E8F8EE;
  color: #34C759;
}
.badge-paused {
  background: #FFF4E0;
  color: #FF9500;
}
.badge-unknown {
  background: #F0F0F0;
  color: #999;
}

/* 删除按钮 */
.rel-card-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.85);
  z-index: 5;
}

/* ---- 卡片主体 ---- */
.rel-card-body {
  padding: 24rpx 28rpx 0;
}

/* 信息栏：状态 / 持续 / 断联 */
.rel-card-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #f5f5f8;
  border-radius: 16rpx;
  padding: 14rpx 12rpx;
}
.rel-info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}
.rel-info-label {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 4rpx;
}
.rel-info-value {
  font-size: 28rpx;
  color: #444;
  font-weight: 500;
}
.rel-info-highlight {
  color: #e85a4f;
  font-weight: 700;
  font-size: 30rpx;
}
/* 状态文字颜色 */
.rel-text-active { color: #e85a4f; }
.rel-text-done { color: #34C759; }
.rel-text-paused { color: #e8891a; }
.rel-text-unknown { color: #888; }
.rel-info-divider {
  width: 2rpx;
  height: 36rpx;
  background: #ddd;
  margin: 0 4rpx;
  flex-shrink: 0;
}

/* 日期区间 */
.rel-card-dates {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  gap: 8rpx;
}
.rel-date-text {
  font-size: 24rpx;
  color: #888;
}
.rel-date-arrow {
  font-size: 22rpx;
  color: #ccc;
}

/* 进度条 */
.rel-card-progress {
  margin-top: 20rpx;
}
.rel-progress-track {
  height: 16rpx;
  background: #f0f0f5;
  border-radius: 10rpx;
  overflow: hidden;
}
.rel-progress-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s;
}
.rel-progress-active {
  background: linear-gradient(90deg, #f6685d, #f9a098);
}
.rel-progress-done {
  background: linear-gradient(90deg, #34C759, #60D880);
}
.rel-progress-paused {
  background: linear-gradient(90deg, #FF9500, #FFB340);
}
.rel-progress-unknown {
  background: linear-gradient(90deg, #bbb, #ddd);
}

.rel-progress-bottom {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-top: 8rpx;
}
.rel-progress-label {
  font-size: 22rpx;
  color: #bbb;
}
.rel-progress-remain {
  font-size: 22rpx;
  color: #999;
}
.rel-progress-done {
  color: #1a7a33;
  font-weight: 600;
}

/* 备注预览 */
.rel-card-note {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  background: #fafafc;
  border-radius: 12rpx;
  gap: 8rpx;
}
.rel-note-text {
  font-size: 24rpx;
  color: #777;
  line-height: 1.5;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 图片墙 */
.rel-card-images {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #f0f0f2;
}
.rel-img-item {
  flex: 1;
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  background: #f5f5f7;
}
.rel-img-thumb {
  width: 100%;
  height: 100%;
  display: block;
}
.rel-img-more {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 8rpx 0 8rpx;
}
.rel-img-more-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

/* ---- 卡片脚标 ---- */
.rel-card-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 16rpx 28rpx 20rpx;
}
.rel-footer-text {
  font-size: 20rpx;
  color: #aaa;
}

/* ===== 悬浮新增按钮 ===== */
.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f6685d, #f9a098);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(246,104,93,0.4);
  z-index: 10;
}
