/* Skyline 页面滚动布局 */
page { overflow: hidden; }

/* 感情列表页样式 */

.filter-bar {
  display: flex;
  flex-direction: row;
  padding: 24rpx;
  background: var(--card-bg);
  gap: 16rpx;
}
.filter-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg);
  transition: all 0.2s;
}
.filter-active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}
.filter-active .filter-badge {
  background: rgba(255,255,255,0.3);
  color: #fff;
}
.filter-badge {
  margin-left: 8rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  background: rgba(246,104,93,0.15);
  color: var(--primary);
  font-weight: 600;
}
.filter-badge-done {
  background: rgba(52,199,89,0.15);
  color: var(--success);
}

.list-wrap {
  padding: 16rpx 0 120rpx;
}

/* 感情卡片（与 dashboard 完全一致） */
.relation-card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  margin: 16rpx var(--spacing-h);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.relation-card-done {
  opacity: 0.7;
}
.card-header {
  padding: 28rpx 28rpx 0;
}
.card-header-info {
  margin-left: 20rpx;
  flex: 1;
  min-width: 0;
}
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-subtitle {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 头像 */
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-green { background: linear-gradient(135deg, #34C759, #30D158); }
.avatar-blue { background: linear-gradient(135deg, #5B8DEF, #7AA2F7); }
.avatar-orange { background: linear-gradient(135deg, #FF9500, #FFB340); }
.avatar-gray { background: linear-gradient(135deg, #8E8E93, #AEAEB2); }

.card-body {
  padding: 20rpx 28rpx 28rpx;
}
.progress-wrap {
  position: relative;
}
.progress-hint {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
  display: block;
  text-align: right;
}

/* 悬浮新增按钮 */
.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f6685d, #f9a098);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(246,104,93,0.4);
  z-index: 10;
}
