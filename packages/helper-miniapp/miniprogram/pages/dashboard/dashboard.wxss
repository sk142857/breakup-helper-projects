/* Skyline 页面滚动布局 */
page { overflow: hidden; }

/* 首页仪表盘样式 */

/* 数据概览卡片 */
.stats-card {
  margin: var(--spacing-h);
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
  background: linear-gradient(135deg, #f6685d 0%, #f9a098 100%);
}
.stats-content {
  padding: 40rpx 36rpx;
  position: relative;
  z-index: 1;
}
.stats-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}
.stats-number {
  font-size: 96rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
}
.stats-unit {
  font-size: 36rpx;
  color: rgba(255,255,255,0.8);
  margin-left: 8rpx;
}
.stats-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.75);
  margin-bottom: 32rpx;
  display: block;
}
.stats-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 20rpx 0;
}
.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stats-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.stats-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}
.stats-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.25);
}

/* 区块标题 */
.section-header {
  padding: 16rpx var(--spacing-h) 8rpx;
}

/* 感情卡片 */
.relation-card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  margin: 16rpx var(--spacing-h);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.card-header {
  padding: 28rpx 28rpx 0;
}
.card-header-info {
  margin-left: 20rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}
.card-subtitle {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 头像 */
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-green { background: linear-gradient(135deg, #34C759, #30D158); }
.avatar-blue { background: linear-gradient(135deg, #5B8DEF, #7AA2F7); }
.avatar-orange { background: linear-gradient(135deg, #FF9500, #FFB340); }
.avatar-gray { background: linear-gradient(135deg, #8E8E93, #AEAEB2); }

.card-body {
  padding: 20rpx 28rpx 28rpx;
}
.progress-wrap {
  position: relative;
}
.progress-hint {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
  display: block;
  text-align: right;
}

/* 悬浮新增按钮 */
.fab-btn {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f6685d, #f9a098);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(246,104,93,0.4);
  z-index: 10;
}
