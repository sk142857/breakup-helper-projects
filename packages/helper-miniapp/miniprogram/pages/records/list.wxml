<!-- 断联记录列表页 -->
<t-navbar title="张三 · 断联记录" fixed left-arrow placeholder></t-navbar>
<scroll-view type="custom" scroll-y class="page-scroll">
  <view class="page-container">

    <!-- 统计条 -->
    <view class="summary-bar">
      <text class="summary-text">共 <text class="summary-num">{{total}}</text> 条记录</text>
    </view>

    <!-- 记录列表 -->
    <view class="records-list">
      <!-- AI: block包装wx:for避免迭代器与元素属性冲突 -->
      <block wx:for="{{records}}" wx:key="recordId">
      <view class="record-card">
        <view class="record-top flex-between">
          <view class="record-header flex-row">
            <view class="record-dot record-dot-primary"></view>
            <text class="record-date">{{item.recordDate}}</text>
          </view>
          <view class="record-delete" data-id="{{item.recordId}}" bindtap="onDeleteRecord">
            <t-icon name="delete" size="28rpx" color="#C7C7CC" />
          </view>
        </view>
        <view class="record-body">
          <view class="flex-row mb-16">
            <view wx:if="{{item.recBkStatusLabel}}" class="tag tag-primary">{{item.recBkStatusLabel}}</view>
          </view>
          <text wx:if="{{item.content}}" class="record-text">{{item.content}}</text>
          <view wx:if="{{item.imageList && item.imageList.length > 0}}" class="record-images">
            <image wx:for="{{item.imageList}}" wx:key="fileId" class="record-img" src="{{item.thumbUrl || item.origUrl}}" mode="aspectFill" />
          </view>
          <view wx:elif="{{item.images && item.images.length > 0}}" class="record-images">
            <image wx:for="{{item.images}}" wx:key="*this" class="record-img" src="{{item}}" mode="aspectFill" />
          </view>
        </view>
        <!-- 底部 Emoji 展示 -->
        <view class="record-emoji-bar">
          <text class="record-emoji">{{item.recMoodEmoji}}</text>
        </view>
      </view>
      </block>

      <view wx:if="{{records.length === 0 && !loading}}" class="empty-state">
        <t-icon name="file-text" size="80rpx" color="#ddd" />
        <text class="empty-title">暂无断联记录</text>
        <text class="empty-desc">点击下方按钮新增打卡</text>
      </view>

    </view>

    <!-- 底部按钮 -->
    <view class="bottom-btn">
      <t-button theme="primary" size="large" block icon="add" shape="round" bindtap="onAddRecord">
        新增记录
      </t-button>
    </view>

  </view>
</scroll-view>
