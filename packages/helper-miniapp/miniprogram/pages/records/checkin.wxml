<!-- 新增断联记录页 - 分步卡片 -->
<t-navbar title="新增打卡" fixed left-arrow placeholder></t-navbar>
<scroll-view type="custom" scroll-y class="page-scroll">
  <view class="page-container">

  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view class="step-row">
      <view wx:for="{{steps}}" wx:key="index" class="step-item">
        <view class="step-dot-wrap">
          <view class="step-dot {{index < step ? 'step-done' : ''}} {{index === step ? 'step-current' : ''}}">
            <t-icon wx:if="{{index < step}}" name="check" size="28rpx" color="#fff" />
            <text wx:else>{{index + 1}}</text>
          </view>
          <text class="step-label {{index === step ? 'step-label-active' : ''}}">{{item}}</text>
        </view>
        <view wx:if="{{index < steps.length - 1}}" class="step-line {{index < step ? 'step-line-done' : ''}}"></view>
      </view>
    </view>
  </view>

  <!-- 步骤卡片 -->
  <view class="step-card-wrap">

    <!-- Step 0: 关联信息 -->
    <view class="step-card" wx:if="{{step === 0}}">
      <view class="form-item">
        <view class="form-label">关联感情</view>
        <view class="form-row form-row-readonly">
          <view class="form-row-left">
            <view class="mini-avatar avatar-green">
              <t-icon name="user" size="28rpx" color="#fff" />
            </view>
            <text class="form-text">{{relationName}}</text>
          </view>
          <t-icon name="check-circle-filled" size="32rpx" color="#34C759" />
        </view>
      </view>
      <view class="form-item">
        <view class="form-label">记录日期</view>
        <view class="form-row">
          <text class="form-text">{{recordDate}}</text>
        </view>
      </view>
      <view class="date-picker-wrap">
        <picker-view indicator-style="height: 80rpx;" style="width: 100%; height: 340rpx;" value="{{dateIndex}}" bindchange="onDateChange">
          <picker-view-column>
            <block wx:for="{{years}}" wx:key="*this"><view class="picker-item">{{item}}年</view></block>
          </picker-view-column>
          <picker-view-column>
            <block wx:for="{{months}}" wx:key="*this"><view class="picker-item">{{item}}月</view></block>
          </picker-view-column>
          <picker-view-column>
            <block wx:for="{{days}}" wx:key="*this"><view class="picker-item">{{item}}日</view></block>
          </picker-view-column>
        </picker-view>
      </view>
    </view>

    <!-- Step 1: 此刻心情 -->
    <view class="step-card" wx:if="{{step === 1}}">
      <view class="form-item">
        <view class="option-grid option-grid-2">
          <view wx:for="{{moodOptions}}" wx:key="value" class="option-card {{mood === item.value ? 'option-active' : ''}}" data-mood="{{item.value}}" bindtap="onSelectMood">
            <text class="option-emoji">{{item.emoji}}</text>
            <text class="option-label">{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Step 2: 断联状态 -->
    <view class="step-card" wx:if="{{step === 2}}">
      <view class="form-item">
        <view class="form-label">今天断联状态</view>
        <view class="status-list">
          <view wx:for="{{statusOptions}}" wx:key="value" class="status-item {{breakStatus === item.value ? 'status-active' : ''}}" data-status="{{item.value}}" bindtap="onSelectStatus">
            <t-icon name="{{item.icon}}" size="40rpx" color="{{breakStatus === item.value ? item.color : '#ccc'}}" />
            <text>{{item.label}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Step 3: 心情记录 -->
    <view class="step-card" wx:if="{{step === 3}}">
      <view class="form-item">
        <view class="form-label">心情记录（可选）</view>
        <view class="form-textarea-wrap">
          <t-textarea placeholder="记录此刻的心情与想法..." value="{{content}}" bindchange="onContentChange" maxlength="{{500}}" autosize indicator adjust-position="{{false}}" />
        </view>
      </view>
      <view class="form-item">
        <view class="form-label">添加图片</view>
        <view class="upload-grid">
          <view wx:for="{{slots}}" wx:key="*this" class="upload-item">
            <view class="upload-spacer"></view>
            <view class="upload-inner">
              <view wx:if="{{images[item]}}" style="width: 100%; height: 100%; position: relative;">
                <image class="upload-img" src="{{images[item]}}" mode="aspectFill" />
                <view class="upload-delete" data-index="{{item}}" catchtap="onDelImage">
                  <t-icon name="close-circle-filled" size="36rpx" color="#FF3B30" />
                </view>
              </view>
              <view wx:elif="{{item === 0}}" class="upload-add" bindtap="onChooseImage" data-index="{{item}}">
                <t-icon name="add" size="56rpx" color="#ccc" />
              </view>
              <view wx:else class="upload-placeholder" bindtap="onChooseImage" data-index="{{item}}">
                <t-icon name="image" size="48rpx" color="#ccc" />
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

  </view>

  <!-- 底部按钮组 -->
  <view class="form-bottom step-bottom">
  <t-button wx:if="{{step > 0}}" theme="default" size="large" shape="round" t-class="btn-half" bindtap="onPrevStep">
    上一步
  </t-button>
  <t-button wx:if="{{step < steps.length - 1}}" theme="primary" size="large" shape="round" t-class="{{step > 0 ? 'btn-half' : 'btn-full'}}" bindtap="onNextStep">
    下一步
  </t-button>
  <t-button wx:if="{{step === steps.length - 1}}" theme="primary" size="large" shape="round" t-class="{{step > 0 ? 'btn-half' : 'btn-full'}}" bindtap="onSave">
    保存记录
  </t-button>
  </view>

  </view>
</scroll-view>
