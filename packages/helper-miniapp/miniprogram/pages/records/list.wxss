/* Skyline 页面滚动布局 */
page { overflow: hidden; background: #f5f5f7; }

/* ===== 感情档案卡片（iOS 风格） ===== */
.rec-profile-card {
  background: #fff;
  margin: 16rpx 20rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04), 0 0 2rpx rgba(0,0,0,0.06);
  padding: 28rpx;
  position: relative;
  overflow: hidden;
}
.rec-profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
}
.rec-profile-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.rec-profile-avatar-img {
  width: 100%;
  height: 100%;
}
.rec-profile-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rec-profile-avatar-char {
  font-size: 34rpx;
  font-weight: 600;
  color: rgba(0,0,0,0.5);
}
.rec-avatar-bg-first_love { background: linear-gradient(135deg, #FFE5E5, #FFB8C6); }
.rec-avatar-bg-ex { background: linear-gradient(135deg, #E8E8F0, #C8C8D8); }
.rec-avatar-bg-crush { background: linear-gradient(135deg, #FFF0E0, #FFD4A8); }
.rec-avatar-bg-situationship { background: linear-gradient(135deg, #E0F0FF, #A8D0F0); }
.rec-avatar-bg-blind_date { background: linear-gradient(135deg, #E8FFE8, #B8E8B8); }
.rec-avatar-bg-other { background: linear-gradient(135deg, #F0E8FF, #D0C0F0); }

.rec-profile-header-right {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}
.rec-profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}
.rec-profile-type {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

/* 统计信息 */
.rec-profile-stats {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #f5f5f8;
  border-radius: 16rpx;
  padding: 14rpx 12rpx;
  margin-top: 20rpx;
}
.rec-stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}
.rec-stats-num {
  font-size: 28rpx;
  color: #e85a4f;
  font-weight: 700;
}
.rec-stats-label {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}
.rec-stats-divider {
  width: 2rpx;
  height: 36rpx;
  background: #ddd;
  margin: 0 4rpx;
  flex-shrink: 0;
}

/* ===== 记录列表 ===== */
.records-list {
  padding: 16rpx 20rpx 140rpx;
}

/* 加载骨架 */
.record-skeleton {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  animation: shimmer 1.5s infinite;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.skeleton-line-short { width: 40%; }
.skeleton-line-long { width: 90%; }
.skeleton-line-medium { width: 65%; }

/* ===== 记录卡片（iOS 风格） ===== */
.rec-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04), 0 0 2rpx rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
}

/* 卡片顶部 */
.rec-card-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.rec-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}
.rec-date-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.rec-date-dot-cry,
.rec-date-dot-heartbreak,
.rec-date-dot-sad { background: #5B8DEF; }
.rec-date-dot-meh { background: #C7C7CC; }
.rec-date-dot-ok,
.rec-date-dot-happy,
.rec-date-dot-free { background: #34C759; }
.rec-date-dot-strong { background: #FF9500; }
.rec-date-dot-default { background: var(--primary); }

.rec-card-date {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.rec-card-day {
  font-size: 22rpx;
  color: #999;
  background: #f5f5f8;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.rec-card-actions {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}
.rec-card-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

/* 卡片元信息（状态标签 + 情绪） */
.rec-card-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

/* 状态标签 */
.rec-tag {
  padding: 6rpx 18rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.4;
}
.rec-tag-keeping {
  background: #E8F8EE;
  color: #34C759;
}
.rec-tag-almost {
  background: #FFF4E0;
  color: #FF9500;
}
.rec-tag-broken {
  background: #FFF0EE;
  color: #FF3B30;
}
.rec-tag-contacted {
  background: #E8F0FF;
  color: #5B8DEF;
}

/* 情绪 emoji */
.rec-card-emoji {
  font-size: 44rpx;
  line-height: 1;
}

/* 文字内容 */
.rec-card-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
  display: block;
}

/* 图片墙（flex:1 三列） */
.rec-card-images {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f0f0f2;
}
.rec-img-item {
  flex: 1;
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  background: #f5f5f7;
}
.rec-img-thumb {
  width: 100%;
  height: 100%;
  display: block;
}
.rec-img-more {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 8rpx 0 8rpx;
}
.rec-img-more-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 20vh;
}
.empty-title {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 24rpx;
}
.empty-desc {
  font-size: 24rpx;
  color: #d0d0d0;
  margin-top: 8rpx;
}

/* ===== 底部按钮 ===== */
.bottom-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, #f5f5f7 40%);
}
