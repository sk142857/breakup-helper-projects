<!-- 感情断联页面 -->
<t-navbar title="断联综合" fixed left-arrow placeholder bind:left-arrow="onBack"></t-navbar>
<scroll-view type="custom" scroll-y class="page-scroll">
  <view class="page-container">

    <!-- 感情档案摘要（iOS 卡片风格） -->
    <view class="profile-card">
      <!-- 右上：删除 -->
      <view class="profile-btn-top" catchtap="onDeleteRelation">
        <t-icon name="delete" size="32rpx" color="#C7C7CC" />
      </view>
      <!-- 右下：修改 -->
      <view class="profile-btn-bottom" catchtap="onEditRelation">
        <t-icon name="edit-1" size="32rpx" color="#C7C7CC" />
      </view>

      <!-- 头部：头像 + 昵称 + 类型 -->
      <view class="profile-header">
        <view class="profile-avatar">
          <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill" class="profile-avatar-img" />
          <view wx:else class="profile-avatar-placeholder {{'profile-avatar-bg-' + (relType || 'other')}}">
            <text class="profile-avatar-char">{{_avatarChar}}</text>
          </view>
        </view>
        <view class="profile-header-right">
          <text class="profile-name">{{nickname}}</text>
          <text class="profile-type">{{_relTypeEmoji}} {{_relTypeLabel}}</text>
        </view>
      </view>

      <!-- 信息栏：状态 / 持续 / 断联 -->
      <view class="profile-info">
        <view class="profile-info-item">
          <text class="profile-info-label">状态</text>
          <text class="profile-info-value {{'profile-text-' + relStatus}}">{{relStatusLabel}}</text>
        </view>
        <view class="profile-info-divider"></view>
        <view class="profile-info-item">
          <text class="profile-info-label">持续</text>
          <text class="profile-info-value profile-info-highlight">{{_durationText}}</text>
        </view>
        <view class="profile-info-divider"></view>
        <view class="profile-info-item">
          <text class="profile-info-label">断联</text>
          <text class="profile-info-value">{{breakDays}} 天</text>
        </view>
      </view>

      <!-- 日期区间 -->
      <view class="profile-dates">
        <text class="profile-date-text">{{startDate}}</text>
        <text wx:if="{{endDate}}" class="profile-date-arrow">→</text>
        <text wx:if="{{endDate}}" class="profile-date-text">{{endDate}}</text>
      </view>

      <!-- 进度条 -->
      <view class="profile-progress">
        <view class="profile-progress-track">
          <view class="profile-progress-fill {{'profile-progress-' + relStatus}}" style="width: {{Math.min(breakDays / Math.max(breakTargetDays, 1) * 100, 100)}}%;"></view>
        </view>
        <view class="profile-progress-bottom">
          <text class="profile-progress-label">{{breakDays}} / {{breakTargetDays}} 天</text>
        </view>
      </view>

      <!-- 备注 -->
      <view wx:if="{{note}}" class="profile-note">
        <text class="profile-note-text">{{note}}</text>
      </view>

      <!-- 图片墙 -->
      <view wx:if="{{_displayImages && _displayImages.length > 0}}" class="profile-images">
        <view wx:for="{{_displayImages}}" wx:for-item="img" wx:key="fileId" class="profile-img-item">
          <image src="{{img.thumbUrl || img.origUrl}}" mode="aspectFill" class="profile-img-thumb" />
          <view wx:if="{{_imageMore && index === 2}}" class="profile-img-more">
            <text class="profile-img-more-text">+{{_imageMore}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 综合统计 -->
    <view class="stats-row-card">
      <view class="stats-item-box">
        <text class="stats-num">{{totalSessions}}</text>
        <text class="stats-label">总断联次数</text>
      </view>
      <view class="stats-divider-v"></view>
      <view class="stats-item-box">
        <text class="stats-num stats-num-warning">{{activeSessions}}</text>
        <text class="stats-label">进行中</text>
      </view>
      <view class="stats-divider-v"></view>
      <view class="stats-item-box">
        <text class="stats-num">{{totalRecords}}</text>
        <text class="stats-label">总打卡次数</text>
      </view>
    </view>

    <!-- 断联列表标题 -->
    <view class="section-header">
      <text class="section-title">断联列表</text>
    </view>

    <!-- 断联期卡片列表 -->
    <view class="session-list">
      <block wx:for="{{sessions}}" wx:key="sessionId">
      <view class="session-card {{item.status === 'done' ? 'session-card-done' : ''}}" data-session-id="{{item.sessionId}}" bindtap="onViewSessionRecords" hover-class="card-tap" hover-stay-time="100">
        <!-- 卡片头部 -->
        <view class="session-card-header">
          <view class="session-card-left">
            <view class="session-dot {{item.status === 'active' ? 'session-dot-active' : 'session-dot-done'}}"></view>
            <view class="session-card-info">
              <view class="session-card-title-row">
                <text class="session-card-status">{{item.statusLabel}}</text>
                <text class="initiator-tag {{item.initiator === 'self' ? 'initiator-self' : 'initiator-other'}}">{{item.initiatorLabel}}</text>
              </view>
              <text class="session-card-date">{{item.startDate}} ~ {{item.endDate || '至今'}}</text>
            </view>
          </view>
          <view class="session-delete-btn" data-session-id="{{item.sessionId}}" catchtap="onDeleteSession">
            <t-icon name="delete" size="32rpx" color="#C7C7CC" />
          </view>
        </view>

        <!-- 备注 -->
        <view wx:if="{{item.note}}" class="session-card-note">
          <text class="session-note-text">{{item.note}}</text>
        </view>

        <!-- 进度 -->
        <view class="session-card-body">
          <view class="flex-between mb-12">
            <text class="text-secondary">已坚持 {{item.recordCount}} 天</text>
            <text class="text-hint">目标 {{item.targetDays}} 天</text>
          </view>
          <t-progress percentage="{{Math.min(item.recordCount / item.targetDays * 100, 100)}}" stroke-width="12rpx" color="{{item.status === 'done' ? '#34C759' : '#f6685d'}}" track-color="#fde8e5" />
        </view>
      </view>
      </block>

      <!-- 空状态 -->
      <view wx:if="{{sessions.length === 0 && !loading}}" class="empty-state">
        <t-icon name="file-text" size="100rpx" color="#ddd" />
        <text class="empty-title">还没有断联记录</text>
        <text class="empty-desc">开始一段新的断联期吧</text>
      </view>
    </view>

  </view>
</scroll-view>

<!-- 底部新增按钮 -->
<view class="bottom-bar">
  <t-button theme="primary" size="large" block shape="round" bindtap="onNewBreakSession">
    新增断联
  </t-button>
</view>
