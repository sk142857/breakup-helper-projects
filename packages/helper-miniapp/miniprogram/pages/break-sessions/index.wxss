/* 断联综合页面样式 */

/* 顶部留空给 navbar */
page { overflow: hidden; }
.page-container {
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* 感情档案（iOS 卡片风格） */
.profile-card {
  background: #fff;
  margin: var(--spacing-h);
  border-radius: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04), 0 0 2rpx rgba(0,0,0,0.06);
  padding: 28rpx 28rpx 0;
  position: relative;
  overflow: hidden;
}
.profile-btn-top {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.profile-btn-bottom {
  position: absolute;
  bottom: 20rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

/* 头部：头像 + 右侧文字 */
.profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-right: 80rpx;
}
.profile-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  flex-shrink: 0;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.profile-avatar-img {
  width: 100%;
  height: 100%;
}
.profile-avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.profile-avatar-char {
  font-size: 36rpx;
  font-weight: 600;
  color: rgba(0,0,0,0.5);
}
.profile-avatar-bg-first_love { background: linear-gradient(135deg, #FFE5E5, #FFB8C6); }
.profile-avatar-bg-ex { background: linear-gradient(135deg, #E8E8F0, #C8C8D8); }
.profile-avatar-bg-crush { background: linear-gradient(135deg, #FFF0E0, #FFD4A8); }
.profile-avatar-bg-situationship { background: linear-gradient(135deg, #E0F0FF, #A8D0F0); }
.profile-avatar-bg-blind_date { background: linear-gradient(135deg, #E8FFE8, #B8E8B8); }
.profile-avatar-bg-other { background: linear-gradient(135deg, #F0E8FF, #D0C0F0); }

.profile-header-right {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}
.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}
.profile-type {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

/* 信息栏 */
.profile-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #f5f5f8;
  border-radius: 16rpx;
  padding: 14rpx 12rpx;
  margin-top: 24rpx;
}
.profile-info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}
.profile-info-label {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 4rpx;
}
.profile-info-value {
  font-size: 28rpx;
  color: #444;
  font-weight: 500;
}
.profile-info-highlight {
  color: #e85a4f;
  font-weight: 700;
  font-size: 30rpx;
}
.profile-text-active { color: #e85a4f; }
.profile-text-done { color: #34C759; }
.profile-text-paused { color: #e8891a; }
.profile-text-unknown { color: #888; }
.profile-info-divider {
  width: 2rpx;
  height: 36rpx;
  background: #ddd;
  margin: 0 4rpx;
  flex-shrink: 0;
}

/* 日期区间 */
.profile-dates {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  gap: 8rpx;
}
.profile-date-text {
  font-size: 24rpx;
  color: #888;
}
.profile-date-arrow {
  font-size: 22rpx;
  color: #ccc;
}

/* 进度条 */
.profile-progress {
  margin-top: 20rpx;
}
.profile-progress-track {
  height: 16rpx;
  background: #f0f0f5;
  border-radius: 10rpx;
  overflow: hidden;
}
.profile-progress-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s;
}
.profile-progress-active {
  background: linear-gradient(90deg, #f6685d, #f9a098);
}
.profile-progress-done {
  background: linear-gradient(90deg, #34C759, #60D880);
}
.profile-progress-paused {
  background: linear-gradient(90deg, #FF9500, #FFB340);
}
.profile-progress-bottom {
  display: flex;
  justify-content: flex-end;
  margin-top: 8rpx;
}
.profile-progress-label {
  font-size: 22rpx;
  color: #888;
}

/* 备注 */
.profile-note {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 16rpx 18rpx;
  background: #fafafc;
  border-radius: 12rpx;
}
.profile-note-text {
  font-size: 24rpx;
  color: #777;
  line-height: 1.5;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 图片墙 */
.profile-images {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  margin-top: 12rpx;
  padding: 12rpx 0 20rpx;
  border-top: 2rpx solid #f0f0f2;
}
.profile-img-item {
  flex: 1;
  aspect-ratio: 1;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  background: #f5f5f7;
}
.profile-img-thumb {
  width: 100%;
  height: 100%;
  display: block;
}
.profile-img-more {
  position: absolute;
  top: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 8rpx 0 8rpx;
}
.profile-img-more-text {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

/* 综合统计条 */
.stats-row-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--card-bg);
  margin: 0 var(--spacing-h) var(--spacing-h);
  padding: 28rpx 16rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
}
.stats-item-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stats-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
}
.stats-num-warning {
  color: var(--primary);
}
.stats-label {
  font-size: 22rpx;
  color: var(--text-hint);
}
.stats-divider-v {
  width: 2rpx;
  height: 48rpx;
  background: #eee;
}

/* 备注 */
.session-card-note {
  border-top: 2rpx solid #f5f5f5;
  margin-top: 16rpx;
  padding-top: 16rpx;
}
.session-note-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-all;
}

/* 断联列表标题 */
.section-header {
  padding: 16rpx var(--spacing-h) 8rpx;
}
.add-session-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #f6685d;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  border: 2rpx solid #fde8e5;
}

/* 断联期卡片 */
.session-list {
  padding: 0 var(--spacing-h) 160rpx;
}
.session-card {
  background: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
  margin-bottom: 20rpx;
  padding: 28rpx;
  overflow: hidden;
}
.session-card-done {
  opacity: 0.8;
}
.card-tap {
  opacity: 0.7;
}
.session-card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.session-card-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}
.session-card-info {
  flex: 1;
  min-width: 0;
}
.session-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.session-dot-active {
  background: #f6685d;
}
.session-dot-done {
  background: #34C759;
}
.session-card-status {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}
.session-card-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}
.initiator-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  line-height: 1.6;
}
.initiator-self {
  background: #e8f5e9;
  color: #2e7d32;
}
.initiator-other {
  background: #fce4ec;
  color: #c62828;
}
.session-card-date {
  font-size: 22rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.session-delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 进度 */
.session-card-body {
  margin-top: 20rpx;
    margin-bottom: 20rpx;
}
.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.mb-12 {
  margin-bottom: 12rpx;
}
.text-secondary {
  font-size: 24rpx;
  color: var(--text-secondary);
}
.text-hint {
  font-size: 22rpx;
  color: var(--text-hint);
}



/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-title {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 24rpx;
}
.empty-desc {
  font-size: 24rpx;
  color: #d0d0d0;
  margin-top: 8rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx var(--spacing-h) calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid var(--border);
}

/* tag */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-primary {
  background: #fde8e5;
  color: #f6685d;
}
.tag-warning {
  background: #fff3e0;
  color: #FF9500;
}
.tag-success {
  background: #e8f5e9;
  color: #34C759;
}
.tag-default {
  background: #f5f5f5;
  color: #999;
}

/* 自定义变量 */
page {
  --card-bg: #FFFFFF;
  --spacing-h: 20rpx;
  --radius-lg: 24rpx;
  --shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  --text-primary: #1a1a2e;
  --text-secondary: #666;
  --text-hint: #999;
  --border: #eee;
  --primary: #f6685d;
  --warning: #FF9500;
  --danger: #FF3B30;
}
