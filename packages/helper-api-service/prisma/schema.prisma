generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ 用户表 ============
model User {
  userId     BigInt    @id @map("user_id")
  openId     String    @unique @map("open_id") @db.VarChar(64)
  unionId    String?   @map("union_id") @db.VarChar(64)
  nickname   String    @default("断联者") @db.VarChar(50)
  avatarUrl  String?   @map("avatar_url") @db.VarChar(500)
  phone      String?   @db.VarChar(20)
  userStatus String    @default("active") @map("user_status") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.DateTime

  @@map("t_users")
}

// ============ 第三方应用（Open API 调用方）============
model AppClient {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  appKey     String    @unique @map("app_key") @db.VarChar(64)
  appSecret  String    @map("app_secret") @db.VarChar(128)
  status     String    @default("active") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.DateTime

  @@map("app_clients")
}

// ============ 微信应用配置 ============
model WechatApp {
  appId     String   @id @map("app_id") @db.VarChar(32)
  appType   String   @map("app_type") @db.VarChar(20)
  appSecret String   @map("app_secret") @db.VarChar(64)
  appName   String?  @map("app_name") @db.VarChar(50)
  appStatus String   @default("active") @map("app_status") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime

  @@map("t_wechat_apps")
}

// ============ SDK 数据采集 ============

model SdkDeviceInfo {
  infoId         String    @id @map("info_id") @db.VarChar(64)
  openId         String?   @map("open_id") @db.VarChar(64)
  userId         BigInt?   @map("user_id")
  md5Str         String?   @map("md5_str") @db.VarChar(64)
  abi            String?   @db.VarChar(128)
  deviceAbi      String?   @map("device_abi") @db.VarChar(128)
  benchmarkLevel Int?      @map("benchmark_level")
  modelLevel     Int?      @map("model_level")
  brand          String?   @db.VarChar(128)
  model          String?   @db.VarChar(128)
  systemName     String?   @map("system_name") @db.VarChar(128)
  platform       String?   @db.VarChar(128)
  cpuType        String?   @map("cpu_type") @db.VarChar(128)
  memorySize     String?   @map("memory_size") @db.VarChar(128)
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt     DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_device_info")
}

model SdkAppBaseInfo {
  infoId            String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId      String?   @map("device_info_id") @db.VarChar(64)
  openId            String?   @map("open_id") @db.VarChar(64)
  userId            BigInt?   @map("user_id")
  md5Str            String?   @map("md5_str") @db.VarChar(64)
  sdkVersion        String?   @map("sdk_version") @db.VarChar(50)
  enableDebug       Boolean?  @map("enable_debug")
  hostAppId         String?   @map("host_app_id") @db.VarChar(32)
  language          String?   @db.VarChar(32)
  version           String?   @db.VarChar(32)
  theme             String?   @db.VarChar(32)
  fontSizeScaleFactor Decimal? @map("font_size_scale_factor") @db.Decimal(5,2)
  fontSizeSetting   Int?      @map("font_size_setting")
  createdAt         DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt        DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_app_base_info")
}

model SdkBatteryInfo {
  infoId              String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId        String?   @map("device_info_id") @db.VarChar(64)
  userId              BigInt?   @map("user_id") @db.UnsignedBigInt
  md5Str              String?   @map("md5_str") @db.VarChar(64)
  openId              String?   @map("open_id") @db.VarChar(64)
  batteryLevel        Int?      @map("battery_level") @db.UnsignedTinyInt
  isCharging          Boolean?  @map("is_charging")
  isLowPowerModeEnabled Boolean? @map("is_low_power_mode_enabled")
  createdAt           DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt          DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_battery_info")
}

model SdkWindowInfo {
  infoId          String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId    String?   @map("device_info_id") @db.VarChar(64)
  openId          String    @map("open_id") @db.VarChar(64)
  userId          BigInt?   @map("user_id")
  md5Str          String?   @map("md5_str") @db.VarChar(64)
  pixelRatio      Decimal   @map("pixel_ratio") @db.Decimal(10,2)
  screenWidth     Int       @map("screen_width")
  screenHeight    Int       @map("screen_height")
  windowWidth     Int       @map("window_width")
  windowHeight    Int       @map("window_height")
  statusBarHeight Int       @map("status_bar_height")
  safeArea        Json?     @map("safe_area")
  screenTop       Int?      @map("screen_top")
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt      DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_window_info")
}

model SdkNetworkType {
  infoId          String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId    String?   @map("device_info_id") @db.VarChar(64)
  networkType     String?   @map("network_type") @db.VarChar(100)
  signalStrength  Int?      @map("signal_strength")
  hasSystemProxy  Int?      @map("has_system_proxy")
  weakNet         Int?      @map("weak_net")
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt      DateTime? @map("modified_at") @db.DateTime
  openId          String?   @map("open_id") @db.VarChar(64)
  userId          BigInt?   @map("user_id")
  md5Str          String?   @map("md5_str") @db.VarChar(64)

  @@map("t_wechat_miniprogram_network_type")
}

model SdkSystemSetting {
  infoId             String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId       String?   @map("device_info_id") @db.VarChar(64)
  openId             String?   @map("open_id") @db.VarChar(64)
  userId             BigInt?   @map("user_id")
  md5Str             String?   @map("md5_str") @db.VarChar(64)
  bluetoothEnabled   Boolean?  @map("bluetooth_enabled")
  locationEnabled    Boolean?  @map("location_enabled")
  wifiEnabled        Boolean?  @map("wifi_enabled")
  deviceOrientation  String?   @map("device_orientation") @db.VarChar(50)
  createdAt          DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt         DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_system_setting")
}

model SdkSkylineInfo {
  infoId       String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId String?   @map("device_info_id") @db.VarChar(64)
  openId       String?   @map("open_id") @db.VarChar(64)
  userId       BigInt?   @map("user_id")
  md5Str       String?   @map("md5_str") @db.VarChar(64)
  isSupported  Boolean?  @map("is_supported")
  version      String?   @db.VarChar(64)
  appVersion   String?   @map("app_version") @db.VarChar(32)
  reason       String?   @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt   DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_skyline_info")
}

model SdkPerformanceInfo {
  infoId         String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId   String?   @map("device_info_id") @db.VarChar(64)
  userId         BigInt?   @map("user_id") @db.UnsignedBigInt
  md5Str         String?   @map("md5_str") @db.VarChar(64)
  openId         String?   @map("open_id") @db.VarChar(64)
  entryType      String?   @map("entry_type") @db.VarChar(50)
  startTime      BigInt?   @map("start_time") @db.UnsignedBigInt
  duration       Int?      @map("duration") @db.UnsignedInt
  navigationType String?   @map("navigation_type") @db.VarChar(50)
  path           String?   @db.VarChar(255)
  pageId         BigInt?   @map("page_id")
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt     DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_performance_info")
}

model SdkLaunchOptions {
  infoId           String    @id @map("info_id") @db.VarChar(64)
  deviceInfoId     String?   @map("device_info_id") @db.VarChar(64)
  openId           String?   @map("open_id") @db.VarChar(64)
  userId           BigInt?   @map("user_id")
  md5Str           String?   @map("md5_str") @db.VarChar(64)
  path             String?   @db.VarChar(255)
  scene            Int?
  appId            String?   @map("app_id") @db.VarChar(32)
  queryObj         Json?     @map("query_obj")
  shareTicket      String?   @map("share_ticket") @db.VarChar(255)
  referrerInfo     Json?     @map("referrer_info")
  forwardMaterials Json?     @map("forward_materials")
  chatType         Int?      @map("chat_type")
  apiCategory      String?   @map("api_category") @db.VarChar(255)
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime
  modifiedAt       DateTime? @map("modified_at") @db.DateTime

  @@map("t_wechat_miniprogram_launch_options")
}

model SdkEventLog {
  logId         BigInt    @map("log_id")
  timestamp     DateTime  @db.DateTime
  userId        BigInt    @map("user_id")
  openId        String?   @map("open_id") @db.VarChar(128)
  deviceInfoId  String?   @map("device_info_id") @db.VarChar(64)
  eventType     String    @map("event_type") @db.VarChar(64)
  eventName     String?   @map("event_name") @db.VarChar(128)
  pagePath      String?   @map("page_path") @db.VarChar(256)
  pageTitle     String?   @map("page_title") @db.VarChar(128)
  pageQuery     String?   @map("page_query") @db.VarChar(512)
  sessionId     String?   @map("session_id") @db.VarChar(128)
  scene         Int?
  referrerPath  String?   @map("referrer_path") @db.VarChar(256)
  duration      Int?      @db.UnsignedInt
  deviceBrand   String?   @map("device_brand") @db.VarChar(64)
  deviceModel   String?   @map("device_model") @db.VarChar(128)
  osVersion     String?   @map("os_version") @db.VarChar(128)
  platform      String?   @db.VarChar(32)
  appVersion    String?   @map("app_version") @db.VarChar(32)
  wxVersion     String?   @map("wx_version") @db.VarChar(32)
  networkType   String?   @map("network_type") @db.VarChar(32)
  extra         Json?
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime

  @@id([logId, timestamp])
  @@map("t_wechat_miniprogram_event_log")
}

// ============ 数据字典表 ============
model Dict {
  dictId     Int      @id @default(autoincrement()) @map("dict_id")
  dictType   String   @map("dict_type") @db.VarChar(30)
  dictCode   String   @map("dict_code") @db.VarChar(30)
  dictLabel  String   @map("dict_label") @db.VarChar(50)
  dictEmoji  String?  @map("dict_emoji") @db.VarChar(10)
  dictDesc   String?  @map("dict_desc") @db.VarChar(100)
  sortOrder  Int?     @default(0) @map("sort_order")
  dictStatus String?  @default("active") @map("dict_status") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime

  @@unique([dictType, dictCode], name: "uk_dict_type_code")
  @@map("t_dict")
}

// ============ 感情关系表 ============
model Relationship {
  relId           String   @id @map("rel_id") @db.VarChar(6)
  userId          BigInt   @map("user_id")
  nickname        String   @map("nickname") @db.VarChar(50)
  avatarUrl       String?  @map("avatar_url") @db.VarChar(500)
  relType         String   @map("rel_type") @db.VarChar(20)
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  breakTargetDays Int?     @default(100) @map("break_target_days")
  relStatus       String?  @default("active") @map("rel_status") @db.VarChar(20)
  note            String?  @map("note") @db.VarChar(500)
  images          Json?    @map("images")
  createdAt       DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt       DateTime @updatedAt @map("updated_at") @db.DateTime

  records      Record[]
  breakSessions BreakSession[]
  milestones   UserMilestone[]

  @@index([userId], name: "idx_user_id")
  @@index([relStatus], name: "idx_rel_status")
  @@map("t_relationships")
}

// ============ 断联期表（一段感情可有多段分手） ============
model BreakSession {
  sessionId   String   @id @map("session_id") @db.VarChar(12)
  relId       String   @map("rel_id") @db.VarChar(6)
  userId      BigInt   @map("user_id")
  initiator   String   @default("self") @map("initiator") @db.VarChar(10)
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  targetDays  Int      @default(100) @map("target_days")
  status      String   @default("active") @map("status") @db.VarChar(20)
  note        String?  @map("note") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime

  relationship Relationship @relation(fields: [relId], references: [relId])
  records      Record[]

  @@index([relId], name: "idx_session_rel_id")
  @@index([userId], name: "idx_session_user_id")
  @@map("t_break_sessions")
}

// ============ 断联记录表 ============
model Record {
  recordId    Int      @id @default(autoincrement()) @map("record_id")
  relId       String   @map("rel_id") @db.VarChar(6)
  sessionId   String?  @map("session_id") @db.VarChar(12)
  userId      BigInt   @map("user_id")
  recordDate  DateTime @map("record_date") @db.Date
  recMood     String   @map("rec_mood") @db.VarChar(20)
  recBkStatus String?  @map("rec_bk_status") @db.VarChar(20)
  content     String?  @map("content") @db.Text
  images      Json?    @map("images")
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime

  relationship  Relationship  @relation(fields: [relId], references: [relId])
  breakSession  BreakSession? @relation(fields: [sessionId], references: [sessionId])

  @@unique([relId, recordDate], name: "uk_rel_date")
  @@index([userId], name: "idx_user_id")
  @@index([relId], name: "idx_rel_id")
  @@index([sessionId], name: "idx_record_session_id")
  @@map("t_records")
}

// ============ 里程碑定义表 ============
model Milestone {
  msId     Int     @id @default(autoincrement()) @map("ms_id")
  days     Int     @unique
  title    String  @db.VarChar(50)
  emoji    String? @db.VarChar(10)
  sortOrder Int?   @default(0) @map("sort_order")

  userMilestones UserMilestone[]

  @@map("t_milestones")
}

// ============ 用户里程碑达成记录 ============
model UserMilestone {
  umId       Int      @id @default(autoincrement()) @map("um_id")
  userId     BigInt   @map("user_id")
  relId      String   @map("rel_id") @db.VarChar(6)
  msId       Int      @map("ms_id")
  achievedAt DateTime @default(now()) @map("achieved_at")

  relationship Relationship @relation(fields: [relId], references: [relId])
  milestone    Milestone    @relation(fields: [msId], references: [msId])

  @@unique([userId, relId, msId], name: "uk_user_rel_ms")
  @@index([relId], name: "idx_rel_id")
  @@map("t_user_milestones")
}

// ============ 文件上传记录表 ============
model FileUpload {
  fileId     String   @id @map("file_id") @db.VarChar(16)
  userId     BigInt?  @map("user_id")
  fileName   String   @map("file_name") @db.VarChar(255)
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type") @db.VarChar(100)
  fileType   String   @map("file_type") @db.VarChar(20) @default("image")
  storage    String   @map("storage") @db.VarChar(20) @default("local")
  origUrl    String   @map("orig_url") @db.VarChar(500)
  thumbUrl   String?  @map("thumb_url") @db.VarChar(500)
  md5Hash    String?  @map("md5_hash") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime

  @@index([userId], name: "idx_user_id")
  @@map("t_file_uploads")
}

// ============ 后台员工表 ============
model Staff {
  id           Int       @id @default(autoincrement())
  username     String    @unique @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(128)
  displayName  String    @map("display_name") @db.VarChar(50)
  status       String    @default("active") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime

  @@map("t_staff")
}