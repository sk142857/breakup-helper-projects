# ============================================
# 开发环境                              生产环境
# ============================================
# MySQL: 本地 localhost            →  阿里云 RDS
# Redis:  本地 localhost:6379      →  Docker redis-server:6379
# ============================================
#
# 开发环境复制：
#   cp packages/helper-api-service/.env.development packages/helper-api-service/.env
#
# 生产环境复制：
#   cp packages/helper-api-service/.env.production packages/helper-api-service/.env
# ============================================

# 数据库连接
DATABASE_URL="mysql://root:123456@localhost:3306/aliyun_breakup_helper?useUnicode=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci&useSSL=false&rewriteBatchedStatements=true&allowPublicKeyRetrieval=true"

# JWT 密钥（生产环境务必更换为强随机字符串）
JWT_SECRET="your-jwt-secret-change-in-production"

# JWT 过期时间（秒）
JWT_EXPIRES_IN="7200"

# Open API 签名有效期（秒）
SIGNATURE_TTL="300"

# Redis
REDIS_URL="redis://localhost:6379"

# 微信小程序
WECHAT_APPID="your-miniapp-appid"
WECHAT_APPSECRET="your-miniapp-appsecret"
